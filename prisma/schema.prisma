// Esquema de datos de la web del IUCE.
// Base: docs/design/HANDOFF.md → "Esquema Prisma propuesto".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

enum NewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EventStatus {
  UPCOMING
  PAST
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
}

model News {
  id          String     @id @default(cuid())
  title       String
  titleEn     String?
  slug        String     @unique
  excerpt     String?
  excerptEn   String?
  content     String // HTML de TipTap
  contentEn   String?
  coverImage  String?
  category    String
  status      NewsStatus @default(DRAFT)
  // Noticia interna: solo visible en la intranet, nunca en la web pública.
  internal    Boolean    @default(false)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// Patrón mupes: contenido editable de páginas estáticas por bloques.
model ContentBlock {
  id       String @id @default(cuid())
  pageSlug String // "instituto", "formacion", "doctorado", "inicio"
  blockKey String // "perfil-intro", "funciones", … (+ ":en" para inglés)
  content  String

  @@unique([pageSlug, blockKey])
}

model Member {
  id        String         @id @default(cuid())
  name      String
  area      String?
  email     String?
  extension String? // extensión telefónica interna (p. ej. 4634)
  photo     String?
  portalUrl String? // perfil en produccioncientifica.usal.es
  orcid     String? // p. ej. https://orcid.org/0000-0001-9987-5584
  scopus    String? // p. ej. https://www.scopus.com/authid/detail.uri?authorId=…
  role      String? // Directora, Subdirector, Secretario, null = miembro
  active    Boolean        @default(true)
  order     Int            @default(0)
  groupId   String?
  group     ResearchGroup? @relation(fields: [groupId], references: [id])
}

// (El campo image de Event permite ilustrar el evento destacado; se sube
// en Archivos y se pega la URL en el panel de Eventos.)

// Proyectos de investigación competitivos (importados de la memoria de
// acreditación, Tabla 4; gestionables después desde el panel).
model Project {
  id        String   @id @default(cuid())
  title     String
  funder    String? // entidad financiadora y código
  ip        String? // investigador(es) principal(es)
  line      String? // línea de investigación / grupo(s), p. ej. "GRIAL / MOVERE"
  scope     String? // ámbito: Europeo, Internacional, Nacional, Autonómico, Institucional, Local
  amount    String? // importe, texto original ("60.500,00 €")
  period    String? // periodo original legible
  startYear Int?
  endYear   Int?
  active    Boolean  @default(true) // visible en la web
  // ¿Es un proyecto DEL IUCE? La Tabla 4 de la memoria separa dos bloques:
  // los que cumplen los criterios del Instituto (firmados por el IUCE o con
  // más del 50% del equipo del IUCE) y aquellos en los que solo se participa
  // con un porcentaje mínimo. La web pública solo lista los primeros.
  iuceLed   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResearchGroup {
  id      String   @id @default(cuid())
  acronym String
  name    String
  nameEn  String?
  lead    String?
  url     String?
  logo    String?
  chip    String? // distintivo, p. ej. "UIC 081"
  members Member[]
}

model Event {
  id       String      @id @default(cuid())
  title    String
  titleEn  String?
  type     String // Congreso, Seminario, Jornada
  startsAt DateTime
  endsAt   DateTime?
  location String?
  url      String?
  image    String? // ilustración del evento (URL de Archivos)
  status   EventStatus @default(UPCOMING)
}

model FileAsset {
  id        String   @id @default(cuid())
  filename  String
  mimeType  String
  size      Int
  url       String
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  body      String
  status    String   @default("NEW") // NEW | REPLIED
  createdAt DateTime @default(now())
}

// ── Intranet ────────────────────────────────────────────────────────────────
// Acceso por magic link con lista blanca gestionada desde el panel.

model IntranetUser {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  active    Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
}

// Token de un solo uso del magic link (caduca a los 30 minutos).
model IntranetToken {
  identifier String // email
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// Documentos de la intranet. Se guardan FUERA de public/ (storage/intranet)
// y se sirven solo con sesión a través de /api/intranet/files/[id].
model IntranetDocument {
  id          String   @id @default(cuid())
  title       String
  description String?
  filename    String // nombre original, para la descarga
  storedName  String // nombre en storage/intranet
  mimeType    String
  size        Int
  createdAt   DateTime @default(now())
}

// Visibilidad de las páginas públicas (panel → Visualización). Sin fila = la
// página se ve; se crea/actualiza al usar el interruptor del ojo.
model PageVisibility {
  slug      String   @id // clave del registro de public-pages.ts
  hidden    Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

// Analítica ligera (patrón mupes).
model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  visitorId String
  date      DateTime @default(now())
}
