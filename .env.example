# Copia este archivo como .env y rellena los valores.

# PostgreSQL local (arranca con: docker compose up -d)
# Puerto 5433 en el host: el 5432 lo usa el postgres de IUCE-Reservas-TFG
DATABASE_URL=postgresql://iuce:iuce2024@localhost:5433/iuce_web

# NextAuth.js v5 (Credentials: email + contraseña)
NEXTAUTH_URL=http://localhost:3000
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET=cambia-este-secret-en-produccion

# Resend (formulario de contacto → email a iuce@usal.es)
# https://resend.com — plan gratis: 100 emails/día
RESEND_API_KEY=re_placeholder
EMAIL_FROM=IUCE <onboarding@resend.dev>
CONTACT_TO=iuce@usal.es

# DeepL (auto-traducción ES→EN al guardar; opcional)
# https://www.deepl.com/pro-api — plan gratuito: 500k caracteres/mes.
# Las claves free terminan en ":fx". Sin clave, la traducción se omite.
DEEPL_API_KEY=deepl-placeholder
